# ===========================
# NaviAid – Environment Variables
# Copy this file to .env and fill in your values
# ===========================

# --- PostgreSQL ---
POSTGRES_USER=naviaid
POSTGRES_PASSWORD=naviaid_secret
POSTGRES_DB=naviaid
DATABASE_URL=postgresql+asyncpg://naviaid:naviaid_secret@localhost:5432/naviaid

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Auth ---
SECRET_KEY=change_me_to_a_secure_random_64char_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Google OAuth (optional for local dev) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_POSTHOG_KEY=phx_your_posthog_key_here

# --- ML ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
OLLAMA_URL=http://localhost:11434

# --- App Settings ---
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_EMAIL=admin@naviaid.in
ADMIN_PASSWORD=Admin@NaviAid2024

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
